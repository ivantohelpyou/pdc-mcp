# Washington State data.wa.gov credentials
# Get a free app token at: https://data.wa.gov/profile/app_tokens
#
# Option A: Simple app token (easier, shared rate limit pool)
PDC_APP_TOKEN=your_app_token_here
#
# Option B: API Key (dedicated rate limit pool — better for heavy use)
# PDC_KEY_ID=your_key_id_here
# PDC_KEY_SECRET=your_key_secret_here
#
# Both options work. App token is fine for most research use.
# Without any credentials, queries still work but hit the shared throttled pool.
